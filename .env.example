# ─────────────────────────────────────────────────────────────
#  YTIGDL — przykładowa konfiguracja. Skopiuj do `.env`.
# ─────────────────────────────────────────────────────────────

# Port serwera
PORT=3000

# Limit darmowych pobrań na konto (potem wymagany klucz licencyjny)
FREE_DOWNLOAD_LIMIT=5

# Ścieżka do binarki yt-dlp (jeśli nie ma w PATH, podaj pełną ścieżkę)
YTDLP_PATH=yt-dlp

# Folder na pobrane pliki (tymczasowy)
DOWNLOAD_DIR=downloads

# ── Firebase Admin SDK (backend) ──────────────────────────────
# Wklej całą zawartość pliku service account JSON w jednej linii,
# ALBO ustaw FIREBASE_SERVICE_ACCOUNT_PATH na ścieżkę do pliku.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=

# Adresy e-mail administratorów (oddzielone przecinkami).
# Tylko oni mają dostęp do panelu admina i wydawania licencji.
ADMIN_EMAILS=frydrychdent@me.com

# ── Firebase Web SDK (frontend, wartości PUBLICZNE) ───────────
# Z konsoli Firebase → Ustawienia projektu → Twoje aplikacje (web).
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
